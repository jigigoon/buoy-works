# EditorConfig helps maintain consistent coding styles for multiple developers 
# working on the same project using various IDEs and editors.
# Visit https://editorconfig.org for more information.

root = true

[*]
# Use UTF-8 encoding for all files
charset = utf-8
# Limit the length of a line to 100 characters for better readability
max_line_length = 100
# Use Unix-style line endings (Line Feed)
end_of_line = lf
# Always end files with a newline character
insert_final_newline = true
# Remove any whitespace characters before a newline
trim_trailing_whitespace = true

# C/C++ Source and Header files
[*.{cpp,cc,cxx,c,h,hpp,inl,tpp}]
# Use spaces instead of tabs
indent_style = space
# Set indentation size to 2 spaces
indent_size = 2

# JSON configuration files
[*.json]
# Use spaces instead of tabs
indent_style = space
# Set indentation size to 2 spaces
indent_size = 2

# Special case for CMakeLists.txt
[{CMakeLists.txt}]
# Use spaces instead of tabs
indent_style = space
# Set indentation size to 2 spaces
indent_size = 2

# Markdown files
[*.md]
# Disable trailing whitespace trimming to preserve Markdown's 
# hard line break syntax (two spaces at the end of a line)
trim_trailing_whitespace = false
